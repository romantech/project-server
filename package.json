{
  "name": "project-server",
  "version": "1.0.0",
  "description": "Personal project server that provides a RESTful API",
  "main": "server.ts",
  "packageManager": "pnpm@10.30.3",
  "_moduleAliases": {
    "@": "dist"
  },
  "scripts": {
    "start:dev": "tsnd -r dotenv/config -r tsconfig-paths/register --respawn --transpile-only src/server.ts",
    "start": "node -r module-alias/register dist/server.js",
    "build": "tsc",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "test": "echo \"Error: no test specified\" && exit 1",
    "type-check": "tsc --noEmit"
  },
  "engines": {
    "node": "24.*"
  },
  "keywords": [],
  "author": "Romantech",
  "license": "ISC",
  "dependencies": {
    "@langchain/core": "^1.1.30",
    "@langchain/openai": "^1.2.12",
    "@types/request-ip": "^0.0.41",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "express": "^4.22.1",
    "express-validator": "^7.3.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.0",
    "jsonrepair": "^3.13.2",
    "langchain": "^1.2.29",
    "module-alias": "^2.3.4",
    "morgan": "^1.10.1",
    "node-schedule": "^2.1.1",
    "openai": "^6.25.0",
    "request-ip": "^3.3.0",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.7",
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/express-serve-static-core": "^5.1.1",
    "@types/module-alias": "^2.0.4",
    "@types/morgan": "^1.9.10",
    "@types/node": "^22.19.13",
    "@types/node-schedule": "^2.1.8",
    "dotenv": "^16.6.1",
    "ts-node-dev": "^2.0.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3"
  }
}
